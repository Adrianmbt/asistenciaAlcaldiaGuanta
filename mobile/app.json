{
  "expo": {
    "name": "Alcaldía de Guanta",
    "slug": "alcaldia-guanta",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#009fa1"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ve.gob.guanta.acceso"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#009fa1"
      },
      "package": "ve.gob.guanta.acceso"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",

      [
        "expo-camera",
        {
          "cameraPermission": "La aplicación necesita acceso a la cámara para escanear códigos QR."
        }
      ]
    ]
  }
}
